rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Verifica se o usuário autenticado é o dono da loja
    function isOwner(email) {
      return request.auth != null && request.auth.token.email.lower() == email.lower();
    }

    match /users/{email} {
      
      // Configuração de chaves de dados gerais da loja
      match /data/{key} {
        // Chaves públicas e chaves de clientes/pedidos para login e histórico do catálogo
        allow read: if key in ['store_profile', 'products', 'coupons', 'product_categories', 'clients', 'orders'] || isOwner(email);
        
        // Escrita em qualquer chave e leitura de chaves privadas de controle (agenda, rotas, etc.): apenas o dono
        allow read, write: if isOwner(email);
      }

      // Fila de pedidos de entrada (enviados pelos clientes, consumidos pelo dono)
      match /incoming_orders/{orderId} {
        // Qualquer pessoa navegando no catálogo pode enviar ou atualizar um pedido
        allow create, update: if true;
        // Apenas o dono pode ler ou excluir pedidos da fila de processamento
        allow read, delete: if isOwner(email);
      }

      // Fila de clientes de entrada (enviados pelos clientes, consumidos pelo dono)
      match /incoming_clients/{clientId} {
        // Qualquer pessoa se cadastrando no catálogo pode criar/atualizar seu perfil de cliente
        allow create, update: if true;
        // Apenas o dono pode ler ou limpar da fila de processamento
        allow read, delete: if isOwner(email);
      }
    }

    match /slugs/{slug} {
      allow read: if true;
      allow create, update: if request.auth != null && request.resource.data.email.lower() == request.auth.token.email.lower();
    }
  }
}
